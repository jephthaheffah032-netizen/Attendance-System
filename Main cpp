void studentManagementMenu() {
    int choice;
    do {
        cout << "\n--- Student Management ---\n";
        cout << "1. Register a new student\n";
        cout << "2. View all registered students\n";
        cout << "3. Search student by index number\n";
        cout << "4. Back to main menu\n";
        cout << "Enter choice: ";
        cin >> choice;
        cin.ignore(); // clear newline

        switch (choice) {
            case 1: {
                string idx, name;
                cout << "Enter index number: ";
                getline(cin, idx);
                // Check for duplicate
                auto it = find_if(students.begin(), students.end(),
                                  [&idx](const Student& s) { return s.getIndex() == idx; });
                if (it != students.end()) {
                    cout << "Student with that index already exists!\n";
                    break;
                }
                cout << "Enter student name: ";
                getline(cin, name);
                students.push_back(Student(idx, name));
                saveStudentsToFile();
                cout << "Student registered successfully.\n";
                break;
            }
            case 2:
                if (students.empty()) {
                    cout << "No students registered yet.\n";
                } else {
                    cout << "\nList of registered students:\n";
                    for (const auto& s : students) {
                        s.display();
                    }
                }
                break;
            case 3: {
                string idx;
                cout << "Enter index number to search: ";
                getline(cin, idx);
                bool found = false;
                for (const auto& s : students) {
                    if (s.getIndex() == idx) {
                        cout << "Student found:\n";
                        s.display();
                        found = true;
                        break;
                    }
                }
                if (!found) cout << "No student with that index.\n";
                break;
            }
            case 4:
                cout << "Returning to main menu.\n";
                break;
            default:
                cout << "Invalid choice. Try again.\n";
        }
    } while (choice != 4);
}

void attendanceSessionMenu() {
    int choice;
    do {
        cout << "\n--- Attendance Session Management ---\n";
        cout << "1. Create a new lecture session\n";
        cout << "2. Mark attendance for a session\n";
        cout << "3. Update attendance records\n";
        cout << "4. List all sessions\n";
        cout << "5. Load a session from file\n";
        cout << "6. Back to main menu\n";
        cout << "Enter choice: ";
        cin >> choice;
        cin.ignore();

        switch (choice) {
            case 1: {
                if (students.empty()) {
                    cout << "Please register at least one student first.\n";
                    break;
                }
                string code, date, time;
                int dur;
                cout << "Enter course code: ";
                getline(cin, code);
                cout << "Enter date (YYYY-MM-DD): ";
                getline(cin, date);
                cout << "Enter start time (HH:MM): ";
                getline(cin, time);
                cout << "Enter duration (minutes): ";
                cin >> dur;
                cin.ignore();

                AttendanceSession newSession(code, date, time, dur);
                newSession.initialiseRecords(students);
                sessions.push_back(newSession);
                newSession.saveToFile();  // save immediately
                cout << "Session created and saved.\n";
                break;
            }
            case 2: {
                if (sessions.empty()) {
                    cout << "No sessions available. Create one first.\n";
                    break;
                }
                // Show list of sessions for selection
                cout << "Available sessions:\n";
                for (size_t i = 0; i < sessions.size(); ++i) {
                    cout << i+1 << ". " << sessions[i].getCourseCode() << " on "
                         << sessions[i].getDate() << " at " << sessions[i].getStartTime() << endl;
                }
                cout << "Select session number: ";
                int sel;
                cin >> sel;
                cin.ignore();
                if (sel < 1 || sel > (int)sessions.size()) {
                    cout << "Invalid selection.\n";
                    break;
                }
                AttendanceSession& sess = sessions[sel-1];

                // Mark attendance for each student
                cout << "\nMarking attendance for " << sess.getCourseCode()
                     << " on " << sess.getDate() << "\n";
                for (const auto& student : students) {
                    cout << student.getName() << " (" << student.getIndex() << ") – ";
                    char status;
                    cout << "Enter status (P/A/L): ";
                    cin >> status;
                    status = toupper(status);
                    while (status != 'P' && status != 'A' && status != 'L') {
                        cout << "Invalid. Enter P, A, or L: ";
                        cin >> status;
                        status = toupper(status);
                    }
                    sess.setStatus(student.getIndex(), status);
                }
                sess.saveToFile();  // update file
                cout << "Attendance marked and saved.\n";
                break;
            }
            case 3: {
                if (sessions.empty()) {
                    cout << "No sessions available.\n";
                    break;
                }
                cout << "Available sessions:\n";
                for (size_t i = 0; i < sessions.size(); ++i) {
                    cout << i+1 << ". " << sessions[i].getCourseCode() << " on "
                         << sessions[i].getDate() << endl;
                }
                cout << "Select session number: ";
                int sel;
                cin >> sel;
                cin.ignore();
                if (sel < 1 || sel > (int)sessions.size()) {
                    cout << "Invalid selection.\n";
                    break;
                }
                AttendanceSession& sess = sessions[sel-1];

                string idx;
                cout << "Enter student index to update: ";
                getline(cin, idx);
                // Verify student exists
                auto studentIt = find_if(students.begin(), students.end(),
                                         [&idx](const Student& s) { return s.getIndex() == idx; });
                if (studentIt == students.end()) {
                    cout << "Student not found.\n";
                    break;
                }
                cout << "Current status: " << sess.getStatus(idx) << endl;
                cout << "Enter new status (P/A/L): ";
                char status;
                cin >> status;
                status = toupper(status);
                cin.ignore();
                if (sess.setStatus(idx, status)) {
                    sess.saveToFile();
                    cout << "Record updated.\n";
                } else {
                    cout << "Failed to update (maybe index not in session).\n";
                }
                break;
            }
            case 4:
                if (sessions.empty()) {
                    cout << "No sessions created yet.\n";
                } else {
                    cout << "\nList of sessions:\n";
                    for (size_t i = 0; i < sessions.size(); ++i) {
                        cout << i+1 << ". " << sessions[i].getCourseCode() << " | "
                             << sessions[i].getDate() << " | " << sessions[i].getStartTime()
                             << " | " << sessions[i].getDuration() << " min\n";
                    }
                }
                break;
            case 5: {
                string fname;
                cout << "Enter session filename (e.g., session_EEE201_2025-03-20.txt): ";
                getline(cin, fname);
                AttendanceSession* loaded = AttendanceSession::loadFromFile(fname, students);
                if (loaded) {
                    sessions.push_back(*loaded);
                    delete loaded;  // we copied it into vector
                    cout << "Session loaded successfully.\n";
                } else {
                    cout << "Failed to load session. File may not exist or format is invalid.\n";
                }
                break;
            }
            case 6:
                cout << "Returning to main menu.\n";
                break;
            default:
                cout << "Invalid choice.\n";
        }
    } while (choice != 6);
}

