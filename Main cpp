// ----------------------------------------------------------------------------
// Student Class
// ----------------------------------------------------------------------------
class Student {
private:
    string indexNumber;   // e.g. "2025001"
    string name;
public:
    Student() {}
    Student(const string& idx, const string& n) : indexNumber(idx), name(n) {}

    string getIndex() const { return indexNumber; }
    string getName() const  { return name; }

    void display() const {
        cout << "Index: " << indexNumber << ", Name: " << name << endl;
    }
};

// ----------------------------------------------------------------------------
// AttendanceSession Class
// ----------------------------------------------------------------------------
class AttendanceSession {
private:
    string courseCode;
    string date;          // format YYYY-MM-DD
    string startTime;     // format HH:MM
    int duration;         // in minutes
    // Record of attendance: each pair stores student index and status (P/A/L)
    vector<pair<string, char>> records;

public:
    AttendanceSession() {}
    AttendanceSession(const string& code, const string& d, const string& time, int dur)
        : courseCode(code), date(d), startTime(time), duration(dur) {}

    // Getters
    string getCourseCode() const { return courseCode; }
    string getDate() const        { return date; }
    string getStartTime() const   { return startTime; }
    int getDuration() const       { return duration; }

    // Initialise records with all students (default status 'A' = Absent)
    void initialiseRecords(const vector<Student>& students) {
        records.clear();
        for (const auto& s : students) {
            records.push_back({s.getIndex(), 'A'});
        }
    }

    // Set status for a specific student (if index exists)
    bool setStatus(const string& index, char status) {
        status = toupper(status);
        if (status != 'P' && status != 'A' && status != 'L') return false;

        for (auto& rec : records) {
            if (rec.first == index) {
                rec.second = status;
                return true;
            }
        }
        return false; // index not found
    }

    // Get status of a student (returns '?' if not found)
    char getStatus(const string& index) const {
        for (const auto& rec : records) {
            if (rec.first == index) return rec.second;
        }
        return '?';
    }

    // Display attendance list with student names (requires student list)
    void displayAttendanceList(const vector<Student>& students) const {
        cout << "\nAttendance for " << courseCode << " on " << date
             << " at " << startTime << " (Duration: " << duration << " min)\n";
        cout << "----------------------------------------------------\n";
        cout << "Index      Name                          Status\n";
        cout << "----------------------------------------------------\n";

        for (const auto& rec : records) {
            // Find student name
            string studentName = "Unknown";
            for (const auto& s : students) {
                if (s.getIndex() == rec.first) {
                    studentName = s.getName();
                    break;
                }
            }
            cout << rec.first << "  " << studentName;
            // Pad with spaces for alignment (simple approach)
            for (size_t i = 0; i < (30 - studentName.length()); ++i) cout << ' ';
            cout << "  " << rec.second << endl;
        }
        cout << "----------------------------------------------------\n";
    }

    // Display summary counts
    void displaySummary() const {
        int present = 0, absent = 0, late = 0;
        for (const auto& rec : records) {
            switch (rec.second) {
                case 'P': present++; break;
                case 'A': absent++;  break;
                case 'L': late++;    break;
            }
        }
        cout << "\nSummary for " << courseCode << " on " << date << ":\n";
        cout << "Present: " << present << "  Absent: " << absent << "  Late: " << late << endl;
    }

    // Save session to a file named: session_COURSE_DATE.txt
    bool saveToFile() const {
        string filename = "session_" + courseCode + "_" + date + ".txt";
        ofstream fout(filename);
        if (!fout) return false;

        fout << courseCode << endl;
        fout << date << endl;
        fout << startTime << endl;
        fout << duration << endl;
        fout << "Index,Status" << endl;   // header
        for (const auto& rec : records) {
            fout << rec.first << "," << rec.second << endl;
        }
        fout.close();
        return true;
    }

    // Static method to load a session from file (returns nullptr on failure)
    static AttendanceSession* loadFromFile(const string& filename, const vector<Student>& students) {
        ifstream fin(filename);
        if (!fin) return nullptr;

        AttendanceSession* session = new AttendanceSession();
        string line;

        // Read courseCode
        getline(fin, session->courseCode);
        // Read date
        getline(fin, session->date);
        // Read startTime
        getline(fin, session->startTime);
        // Read duration
        getline(fin, line);
        session->duration = stoi(line);

        // Read header line (and discard)
        getline(fin, line);

        // Read records
        session->records.clear();
        while (getline(fin, line)) {
            if (line.empty()) continue;
            size_t comma = line.find(',');
            if (comma == string::npos) continue;
            string idx = line.substr(0, comma);
            char stat = line[comma + 1];
            session->records.push_back({idx, stat});
        }
        fin.close();
        return session;
    }

    // For updating an existing record (used when remarking)
    bool updateRecord(const string& index, char newStatus) {
        return setStatus(index, newStatus);
    }
};

// ----------------------------------------------------------------------------
// Global data
// ----------------------------------------------------------------------------
vector<Student> students;
vector<AttendanceSession> sessions;

// ----------------------------------------------------------------------------
// File I/O helpers for students
// ----------------------------------------------------------------------------
void saveStudentsToFile() {
    ofstream fout("students.txt");
    for (const auto& s : students) {
        fout << s.getIndex() << "," << s.getName() << endl;
    }
    fout.close();
}

void loadStudentsFromFile() {
    ifstream fin("students.txt");
    if (!fin) return; // file may not exist yet

    string line;
    while (getline(fin, line)) {
        size_t comma = line.find(',');
        if (comma == string::npos) continue;
        string idx = line.substr(0, comma);
        string name = line.substr(comma + 1);
        students.push_back(Student(idx, name));
    }
    fin.close();
}

// Load all session files from current directory (simple version: hardcoded or by naming pattern)
// For simplicity, we will not auto-load sessions; instead they will be loaded when needed via menu.
// Alternatively, we could scan for files starting with "session_". 
// Here we'll let the user choose to load a session by providing the filename.
// We'll also save each session individually when created/modified.

// ----------------------------------------------------------------------------
