        cout << "2. Display summary counts for a session\n";
        cout << "3. Back to main menu\n";
        cout << "Enter choice: ";
        cin >> choice;
        cin.ignore();

        switch (choice) {
            case 1:
            case 2: {
                if (sessions.empty()) {
                    cout << "No sessions available.\n";
                    break;
                }
                cout << "Available sessions:\n";
                for (size_t i = 0; i < sessions.size(); ++i) {
                    cout << i+1 << ". " << sessions[i].getCourseCode() << " on "
                         << sessions[i].getDate() << endl;
                }
                cout << "Select session number: ";
                int sel;
                cin >> sel;
                cin.ignore();
                if (sel < 1 || sel > (int)sessions.size()) {
                    cout << "Invalid selection.\n";
                    break;
                }
                if (choice == 1)
                    sessions[sel-1].displayAttendanceList(students);
